# Firebase Admin SDK - Service Account Key (JSON stringified)
# Get from: Firebase Console > Project Settings > Service Accounts > Generate new private key
# Then stringify: JSON.stringify(require('./serviceAccountKey.json'))
FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"crystalscan-1858b",...}

# Telegram notification
TELEGRAM_BOT_TOKEN="your_telegram_bot_token"
TELEGRAM_CHAT_ID="your_telegram_chat_id"

# Promotion codes (comma separated)
PROMOTION_CODES="code1,code2,code3"
